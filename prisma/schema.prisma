generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String    @id @default(uuid())
  telegram_id      BigInt   @unique // Telegram ID katta son bo'lishi mumkin
  fullName  String
  createdAt DateTime @default(now())
}

enum ProductType {
  SHINA
  AKKUMULYATOR
  DISKLAR
  EXTIYOT_QISM
  KAMERA
}

model Product {
  id        String      @id @default(uuid())
  name      String 
  type      ProductType 
  price     Float 
  count     Int         @default(0) 
  photos    Photo[] 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type]) 
}

model Photo {
  id        String    @id @default(uuid())
  publicId  String
  url       String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}
